{
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/index.css",
    "src/pages/**/*.tsx",
    "src/components/ChatPanel.tsx",
    "src/components/VideoTile.tsx",
    "src/hooks/useMeetingRoom.ts",
    "src/lib/supabase.ts",
    "src/lib/utils.ts",
    "src/store/useMeetingStore.ts"
  ],
  "exclude": [
    "src/components/ui/**",
    "src/integrations/**",
    "src/routes/**",
    "src/router.tsx",
    "src/routeTree.gen.ts",
    "src/server.ts",
    "src/start.ts",
    "src/lib/anonymous-meeting.ts",
    "src/lib/call-analytics.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
